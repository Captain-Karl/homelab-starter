# Immich is heavier than the other services here (runs its own ML, Postgres,
# and Redis containers) - make sure your host has a few GB of free RAM.

# Pin to a specific release for predictable upgrades, e.g. v1.118.2.
# "release" tracks the latest stable release.
IMMICH_VERSION=release

# Required. Path on the host where your photo/video library will be stored.
IMMICH_UPLOAD_LOCATION=./immich-data/library

IMMICH_DB_USERNAME=postgres
IMMICH_DB_DATABASE_NAME=immich
# Auto-generated by install.sh if left blank.
IMMICH_DB_PASSWORD=
