# Cloudflare API token with Zone:DNS:Edit permission for your domain.
# https://dash.cloudflare.com/profile/api-tokens
CF_DNS_API_TOKEN=

# Email used for Let's Encrypt expiry notices.
ACME_EMAIL=

# Optional: bind Traefik's :80/:443 to one interface only (e.g. your
# Tailscale IP, 100.x.x.x) instead of all interfaces. Leave unset for 0.0.0.0.
TRAEFIK_BIND_ADDRESS=
